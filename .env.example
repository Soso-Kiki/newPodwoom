# ── Google Gemini ──────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급
GOOGLE_API_KEY=여기에_Gemini_API_키_붙여넣기

# ── Anthropic Claude (현재 미사용, 예비) ───────────────────
ANTHROPIC_API_KEY=여기에_Claude_API_키_붙여넣기

# ── OpenAI ─────────────────────────────────────────────────
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=여기에_OpenAI_API_키_붙여넣기

# ── 서버 포트 ───────────────────────────────────────────────
PORT=3001

# ── OpenAI 모델 (기본값: gpt-4o-mini) ──────────────────────
OPENAI_MODEL=gpt-4o-mini
